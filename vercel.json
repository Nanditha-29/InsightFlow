{
  "functions": {
    "api/**/*.py": {
      "runtime": "python3.12",
      "maxDuration": 30,
      "includeFiles": "backend/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" }
  ],
  "buildCommand": "npm install && npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs"
}
